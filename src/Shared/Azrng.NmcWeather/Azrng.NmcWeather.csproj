<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net6.0;net7.0;net8.0;net9.0;net10.0</TargetFrameworks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <DocumentationFile>$(OutputPath)$(AssemblyName).$(TargetFramework).xml</DocumentationFile>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <Authors>Azrng</Authors>
    <Copyright>版权归 Azrng 所有</Copyright>
    <Version>1.0.0</Version>
    <PackageId>Azrng.NmcWeather</PackageId>
    <PackageProjectUrl>https://azrng.github.io/nuget-docs</PackageProjectUrl>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <NoWarn>1701;1702;1591</NoWarn>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Title>NMC Weather Client</Title>
    <PackageTags>weather;nmc;china;forecast;http;dotnet</PackageTags>
    <RepositoryUrl>https://github.com/azrng/nuget-packages</RepositoryUrl>
    <Description>中央气象台天气接口客户端，支持按省份和城市名称或编码查询天气数据。</Description>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Common.HttpClients\Common.HttpClients.csproj" />
  </ItemGroup>

</Project>

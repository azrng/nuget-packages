<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net6.0;net7.0;net8.0;net9.0;net10.0</TargetFrameworks>

        <GenerateDocumentationFile>true</GenerateDocumentationFile>


        <DocumentationFile>$(OutputPath)$(AssemblyName).$(TargetFramework).xml</DocumentationFile>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <Authors>Azrng</Authors>
        <Copyright>版权归Azrng所有</Copyright>
        <VersionPrefix>1.5.0</VersionPrefix>
        <Description>业务配置维护的 ASP.NET Core NuGet 包</Description>
        <PackageId>SettingConfig</PackageId>
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <PackageProjectUrl>https://azrng.gitee.io/nuget-docs/</PackageProjectUrl>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <Title>Setting Configuration</Title>
        <PackageTags>configuration;aspnetcore;dotnet</PackageTags>
        <RepositoryUrl>https://github.com/azrng/nuget-packages</RepositoryUrl>
    </PropertyGroup>

    <ItemGroup>
        <None Remove="wwwroot\index.html"/>
        <None Remove="wwwroot\css\config-dashboard.css"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>

    <ItemGroup>
        <!-- 嵌入优化后的静态资源 -->
        <EmbeddedResource Include="wwwroot\index.html"/>
        <EmbeddedResource Include="wwwroot\css\config-dashboard.css"/>
    </ItemGroup>

    <ItemGroup Condition=" '$(TargetFramework)' == 'net6.0' ">
        <PackageReference Include="Npgsql" Version="6.0.*"/>
    </ItemGroup>

    <ItemGroup Condition=" '$(TargetFramework)' == 'net7.0' ">
        <PackageReference Include="Npgsql" Version="7.0.*"/>
    </ItemGroup>

    <ItemGroup Condition=" '$(TargetFramework)' == 'net8.0' ">
        <PackageReference Include="Npgsql" Version="8.0.*"/>
    </ItemGroup>

    <ItemGroup Condition=" '$(TargetFramework)' == 'net9.0' ">
        <PackageReference Include="Npgsql" Version="9.0.*"/>
    </ItemGroup>

    <ItemGroup Condition=" '$(TargetFramework)' == 'net10.0' ">
        <PackageReference Include="Npgsql" Version="10.0.0"/>
    </ItemGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Azrng.Core" Version="1.15.7"/>
        <PackageReference Include="Common.Dapper" Version="0.2.0"/>
        <PackageReference Include="Newtonsoft.Json" Version="13.*"/>
    </ItemGroup>


</Project>

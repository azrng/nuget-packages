<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <Authors>Azrng</Authors>
    <Company>Azrng</Company>
    <Description>CSRedis 缓存服务提供者，支持依赖注入</Description>
    <Copyright>版权归Azrng所有</Copyright>
    <Version>1.0.2</Version>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Title>CSRedis Cache Provider</Title>
    <PackageTags>cache;redis;csredis;dotnet</PackageTags>
    <RepositoryUrl>https://github.com/azrng/nuget-packages</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CSRedisCore" Version="3.6.6" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="5.0.0" />
  </ItemGroup>

</Project>

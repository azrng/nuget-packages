<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!-- Apache.Arrow 23.x 起需 net8+，Arrow 包不覆盖 net6/net7 -->
        <TargetFrameworks>net10.0;net9.0;net8.0</TargetFrameworks>
        <ImplicitUsings>enable</ImplicitUsings>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        <Description>Azrng.NMaxCompute 的 Arrow 格式读取支持：Tunnel arrow 分帧解码 + Apache.Arrow IPC 解析。</Description>
        <Authors>Azrng</Authors>
        <Company>Azrng</Company>
        <Version>1.0.0</Version>
        <PackageId>Azrng.NMaxCompute.Arrow</PackageId>
        <Copyright>Azrng</Copyright>
        <NoWarn>1701;1702;1591</NoWarn>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <Title>MaxCompute Arrow Reader</Title>
        <PackageTags>maxcompute;odps;alibaba;arrow;dotnet</PackageTags>
        <RepositoryUrl>https://github.com/azrng/nuget-packages</RepositoryUrl>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Apache.Arrow" Version="23.0.0"/>
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="Azrng.NMaxCompute.Arrow.Test"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Azrng.NMaxCompute\Azrng.NMaxCompute.csproj"/>
    </ItemGroup>

</Project>

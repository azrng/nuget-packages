<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
        <Authors>Azrng</Authors>
        <Copyright>版权归Azrng所有</Copyright>
        <Description>Apache Tika Email Parser for .NET - extract text from .eml and .msg files</Description>
        <Version>1.0.0</Version>
        <PackageId>Azrng.NTika.Parsers.Email</PackageId>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <NoWarn>1701;1702;1591</NoWarn>
        <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
        <Title>Azrng NTika Email Parser</Title>
        <PackageTags>tika;parser;email;eml;msg</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="MimeKit" Version="4.17.0" />
        <PackageReference Include="MsgReader" Version="6.0.11" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Azrng.NTika.Core\Azrng.NTika.Core.csproj" />
    </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
        <Authors>Azrng</Authors>
        <Copyright>版权归Azrng所有</Copyright>
        <Description>Apache Tika Core library for .NET - document type detection and parsing framework</Description>
        <Version>1.0.0</Version>
        <PackageId>Azrng.NTika.Core</PackageId>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <NoWarn>1701;1702;1591</NoWarn>
        <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
        <Title>Azrng NTika Core</Title>
        <PackageTags>tika;parser;document;mime;detection</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <EmbeddedResource Include="Resources\tika-mimetypes.xml" />
    </ItemGroup>

</Project>

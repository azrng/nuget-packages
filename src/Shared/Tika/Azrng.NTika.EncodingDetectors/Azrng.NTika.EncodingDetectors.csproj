<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
        <Authors>Azrng</Authors>
        <Copyright>版权归Azrng所有</Copyright>
        <Description>Apache Tika Encoding Detectors for .NET - charset detection from streams</Description>
        <Version>1.0.0</Version>
        <PackageId>Azrng.NTika.EncodingDetectors</PackageId>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <NoWarn>1701;1702;1591</NoWarn>
        <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
        <Title>Azrng NTika Encoding Detectors</Title>
        <PackageTags>tika;encoding;charset;detector</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="System.Text.Encoding.CodePages" Version="8.0.0" />
        <PackageReference Include="UTF.Unknown" Version="2.5.1" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Azrng.NTika.Core\Azrng.NTika.Core.csproj" />
    </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
        <Authors>Azrng</Authors>
        <Copyright>版权归Azrng所有</Copyright>
        <Description>Apache Tika Archive Parser for .NET - list entries in ZIP, TAR, GZ, 7Z, RAR archives</Description>
        <Version>1.0.0</Version>
        <PackageId>Azrng.NTika.Parsers.Archive</PackageId>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <NoWarn>1701;1702;1591</NoWarn>
        <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
        <Title>Azrng NTika Archive Parser</Title>
        <PackageTags>tika;parser;archive;zip;tar;gz;7z</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="SharpCompress" Version="1.0.0" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Azrng.NTika.Core\Azrng.NTika.Core.csproj" />
    </ItemGroup>

</Project>

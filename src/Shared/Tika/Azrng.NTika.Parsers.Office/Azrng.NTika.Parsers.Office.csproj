<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
        <Authors>Azrng</Authors>
        <Copyright>版权归Azrng所有</Copyright>
        <Description>Apache Tika Office Parser for .NET - extracts text from Word, Excel, PowerPoint files</Description>
        <Version>1.0.0</Version>
        <PackageId>Azrng.NTika.Parsers.Office</PackageId>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <NoWarn>1701;1702;1591</NoWarn>
        <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
        <Title>Azrng NTika Office Parser</Title>
        <PackageTags>tika;parser;office;docx;xlsx;pptx;doc;xls;ppt</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="NPOI" Version="2.7.4" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Azrng.NTika.Core\Azrng.NTika.Core.csproj" />
    </ItemGroup>

</Project>

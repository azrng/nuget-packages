<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
        <Authors>Azrng</Authors>
        <Copyright>版权归Azrng所有</Copyright>
        <Description>Apache Tika Language Detection for .NET - text language identification using n-gram profiles</Description>
        <Version>1.0.0</Version>
        <PackageId>Azrng.NTika.LanguageDetect</PackageId>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
        <NoWarn>1701;1702;1591</NoWarn>
        <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
        <Title>Azrng NTika Language Detection</Title>
        <PackageTags>tika;language;detection;nlp</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\Azrng.NTika.Core\Azrng.NTika.Core.csproj" />
    </ItemGroup>

</Project>
